<Window x:Class="NetworkSecurityAuditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NetworkSecurityAuditor.ViewModels"
        xmlns:models="clr-namespace:NetworkSecurityAuditor.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Network Security Auditor"
        Width="1400" Height="900"
        MinWidth="1000" MinHeight="700"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Status enum values for ComboBox -->
        <ObjectDataProvider x:Key="CheckStatusValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:CheckStatus" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{StaticResource PanelBg}"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Score Display -->
                    <Border Background="{StaticResource SurfaceBg}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Grade}" FontSize="56" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding GradeBrushKey, Converter={StaticResource ResourceBrush}}"
                                       AutomationProperties.Name="Overall security grade" />
                            <TextBlock Text="{Binding OverallScoreDisplay}"
                                       HorizontalAlignment="Center" FontSize="22" Foreground="{StaticResource TextSecondary}" />
                            <TextBlock Text="Overall Score" HorizontalAlignment="Center"
                                       FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Ransomware Readiness -->
                    <Border Background="{StaticResource SurfaceBg}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Ransomware Readiness" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RansomwareGrade}" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0" />
                                <TextBlock FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                    <TextBlock.Text>
                                        <Binding Path="RansomwareScore" StringFormat="{}{0}/100" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Domain Maturity -->
                    <Border Background="{StaticResource SurfaceBg}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Domain Maturity" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DomainMaturityGrade}" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0" />
                                <TextBlock FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                    <TextBlock.Text>
                                        <Binding Path="DomainMaturityScore" StringFormat="{}{0}/100" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Pre-flight Summary -->
                    <TextBlock Text="{Binding PreflightSummary}"
                               Foreground="{StaticResource TextSecondary}" FontSize="10"
                               FontFamily="Cascadia Code, Consolas" TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               AutomationProperties.Name="Pre-flight connectivity check results" />

                    <!-- Filters -->
                    <TextBlock Text="FILTERS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Margin="0,0,0,6"
                             AutomationProperties.Name="Search checks" />
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding StatusFilter}"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="Status filter" />

                    <!-- Category List -->
                    <TextBlock Text="CATEGORIES" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6" />
                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             Style="{StaticResource DarkListBox}"
                             ItemContainerStyle="{StaticResource DarkListBoxItem}"
                             MaxHeight="190"
                             Margin="0,0,0,12"
                             AutomationProperties.Name="Check categories" />

                    <!-- Scan Profile -->
                    <TextBlock Text="SCAN PROFILE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="Scan profile selector" />

                    <!-- Theme -->
                    <TextBlock Text="THEME" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme}"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="Theme selector" />

                    <CheckBox Content="Privacy mode"
                              IsChecked="{Binding PrivacyMode}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,0,0,12"
                              AutomationProperties.Name="Privacy mode" />

                    <!-- Scan Buttons -->
                    <Button Content="Start Scan"
                            Command="{Binding StartScanCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,0,6"
                            AutomationProperties.Name="Start security scan" />
                    <Button Content="Stop Scan"
                            Command="{Binding StopScanCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,12"
                            AutomationProperties.Name="Stop running scan" />

                    <!-- State Buttons -->
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="Save State" Command="{Binding SaveStateCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="2"
                                Padding="10,5" FontSize="10" />
                        <Button Content="Load State" Command="{Binding LoadStateCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="2"
                                Padding="10,5" FontSize="10" />
                    </WrapPanel>

                    <TextBlock Text="EXPORT" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ExportFormats}"
                              SelectedItem="{Binding SelectedExportFormat}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,6"
                              AutomationProperties.Name="Export format selector" />
                    <TextBox Text="{Binding ExportOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Margin="0,0,0,6"
                             AutomationProperties.Name="Export output folder" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Browse"
                                Command="{Binding BrowseExportFolderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,5" FontSize="10"
                                AutomationProperties.Name="Browse export folder" />
                        <Button Grid.Column="2" Content="Export"
                                Command="{Binding ExportSelectedCommand}"
                                Style="{StaticResource AccentButton}"
                                Padding="10,5" FontSize="10"
                                AutomationProperties.Name="Export selected format" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <ListBox Grid.Column="1" Grid.Row="0"
                 ItemsSource="{Binding FilteredChecks}"
                 Background="{StaticResource WindowBg}"
                 BorderThickness="0"
                 Margin="16"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 AutomationProperties.Name="Filtered security checks">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Focusable" Value="False" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:CheckItemViewModel}">
                        <Border Background="{StaticResource CardBg}" CornerRadius="8"
                                Margin="0,0,0,8" Padding="16"
                                BorderBrush="{StaticResource SurfaceBg}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Row 0: Header -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Id}" FontFamily="Cascadia Code, Consolas"
                                           FontWeight="Bold" FontSize="14"
                                           Foreground="{StaticResource Accent}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />

                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" />

                                <!-- Severity Badge -->
                                <Border Grid.Row="0" Grid.Column="2"
                                        Background="{Binding SeverityBrushKey, Converter={StaticResource ResourceBrush}}"
                                        CornerRadius="4" Padding="8,2" Margin="8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityLabel}" FontSize="10"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               Foreground="{StaticResource OnAccent}" />
                                </Border>

                                <!-- Status Dropdown -->
                                <ComboBox Grid.Row="0" Grid.Column="3"
                                          ItemsSource="{Binding Source={StaticResource CheckStatusValues}}"
                                          SelectedItem="{Binding Status}"
                                          Width="120" VerticalAlignment="Center"
                                          Style="{StaticResource DarkComboBox}"
                                          AutomationProperties.Name="{Binding Id, StringFormat='Status for {0}'}" />

                                <!-- Status Indicator Bar -->
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                        Background="{Binding StatusBrushKey, Converter={StaticResource ResourceBrush}}"
                                        Height="3" CornerRadius="0" Margin="0,8,0,8" />

                                <!-- Row 2: Findings + Evidence -->
                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Findings"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,2" />
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding Findings, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="40" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             Margin="0,0,8,0" />

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Evidence"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,2" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding Evidence}"
                                             Style="{StaticResource DarkTextBox}"
                                             IsReadOnly="True" TextWrapping="Wrap"
                                             MinHeight="40" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto" />
                                </Grid>

                                <!-- Row 3: Notes -->
                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Notes"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                               Margin="0,4,0,2" />
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="28" MaxHeight="60"
                                             VerticalScrollBarVisibility="Auto"
                                             Margin="0,0,8,0" />

                                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                VerticalAlignment="Bottom" Margin="0,0,8,0">
                                        <TextBlock Text="Assignee" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2" />
                                        <TextBox Text="{Binding RemediationAssignee, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DarkTextBox}" Width="140" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                VerticalAlignment="Bottom">
                                        <TextBlock Text="Due Date" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2" />
                                        <TextBox Text="{Binding RemediationDueDate, StringFormat={}{0:yyyy-MM-dd}, TargetNullValue='', UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, NotifyOnValidationError=True}"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Width="130" />
                                    </StackPanel>
                                </Grid>

                                <!-- Running Indicator -->
                                <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="4"
                                        Background="{StaticResource OverlayScrim}" CornerRadius="8"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Scanning..." FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Accent}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status Bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{StaticResource SurfaceBg}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding ScanStatus}"
                               Foreground="{StaticResource TextSecondary}" FontSize="12"
                               VerticalAlignment="Center" />
                    <ProgressBar Grid.Row="1"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding ScanProgressPercent}"
                                 Height="4" Margin="0,4,0,0"
                                 Background="{StaticResource CardBg}"
                                 Foreground="{StaticResource ProgressGood}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource ProgressGood}" FontSize="12" Margin="0,0,12,0"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="PassCount" StringFormat="Pass: {0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource ProgressMid}" FontSize="12" Margin="0,0,12,0"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="PartialCount" StringFormat="Partial: {0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource ProgressBad}" FontSize="12" Margin="0,0,12,0"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="FailCount" StringFormat="Fail: {0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="NaCount" StringFormat="N/A: {0}" />
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
